# Iskander generated values — created by install.sh
# Generated: {{ ansible_date_time.iso8601 }}
# DO NOT COMMIT THIS FILE — it contains secrets
# Store it securely (e.g., in Vaultwarden after installation completes)

global:
  cooperative:
    name: {{ coop_name | quote }}
    domain: {{ domain | default('') | quote }}
    timezone: "UTC"

  postgresql:
    auth:
      postgresPassword: {{ generated_secrets.pg_root_password | quote }}
      username: "iskander"
      password: {{ generated_secrets.pg_root_password | quote }}
      database: "iskander"

  redis:
    auth:
      password: {{ generated_secrets.redis_password | quote }}

  storageClass: "local-path"
  imagePullPolicy: IfNotPresent

postgresql:
  enabled: true
  auth:
    postgresPassword: {{ generated_secrets.pg_root_password | quote }}
    username: "iskander"
    password: {{ generated_secrets.pg_root_password | quote }}
    database: "iskander"
  primary:
    persistence:
      enabled: true
      size: 10Gi
    initdb:
      scriptsConfigMap: "iskander-initdb"

redis:
  enabled: true
  architecture: standalone
  auth:
    enabled: true
    password: {{ generated_secrets.redis_password | quote }}

authentik:
  enabled: true
  secretKey: {{ generated_secrets.authentik_secret_key | quote }}
  postgresql:
    password: {{ generated_secrets.pg_authentik_password | quote }}
  email:
    host: ""
    from: "noreply@{{ domain | default('localhost') }}"

loomio:
  enabled: true
  secretKeyBase: {{ generated_secrets.loomio_secret_key_base | quote }}
  webhookSecret: {{ generated_secrets.loomio_webhook_secret | quote }}
  postgresql:
    password: {{ generated_secrets.pg_loomio_password | quote }}
  # OIDC client secret is populated by the authentik-bootstrap job post-install
  oidc:
    clientSecret: ""

mattermost:
  enabled: true
  postgresql:
    password: {{ generated_secrets.pg_mattermost_password | quote }}
  oidc:
    clientSecret: ""
  clerkBotToken: ""          # Populated by mattermost-bootstrap job

nextcloud:
  enabled: true
  adminPassword: {{ generated_secrets.pg_root_password | quote }}  # Changed on first login
  postgresql:
    password: {{ generated_secrets.pg_nextcloud_password | quote }}
  oidc:
    clientSecret: ""

openclaw:
  enabled: true
  anthropicApiKey: ""        # Must be set manually after install
  loomio:
    apiKey: ""               # Populated by loomio-bootstrap job
  mattermost:
    outgoingWebhookToken: {{ generated_secrets.mattermost_webhook_secret | quote }}
    botToken: ""             # Populated by mattermost-bootstrap job
    botUserId: ""            # Populated by mattermost-bootstrap job

decisionRecorder:
  postgresql:
    password: {{ generated_secrets.pg_decision_recorder_password | quote }}

vaultwarden:
  enabled: true
  adminToken: {{ generated_secrets.vaultwarden_admin_token | quote }}
  postgresql:
    password: {{ generated_secrets.pg_root_password | quote }}
  oidc:
    clientSecret: ""

backrest:
  enabled: true
  repositoryPassword: {{ generated_secrets.backrest_repo_password | quote }}

beszel:
  enabled: true
  adminPassword: {{ generated_secrets.pg_root_password | quote }}  # Changed on first login

cloudflared:
  enabled: {{ 'true' if not domain else 'false' }}

ipfs:
  enabled: true

# Project Iskander — Environment Variables
# Copy to .env and fill in values. Never commit .env to version control.

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme_in_prod
DATABASE_URL=postgresql+asyncpg://iskander:changeme_in_prod@localhost:5432/iskander_ledger

# ─── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ─── EVM / Anvil ──────────────────────────────────────────────────────────────
EVM_RPC_URL=http://localhost:8545
EVM_CHAIN_ID=31337
# Deployer private key (Anvil account #0 — dev only, never use in prod)
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ─── IPFS ─────────────────────────────────────────────────────────────────────
IPFS_API_URL=http://localhost:5001

# ─── ActivityPub ──────────────────────────────────────────────────────────────
ACTIVITYPUB_DOMAIN=iskander.local
ACTIVITYPUB_BASE_URL=http://iskander.local

# ─── Safe Multi-sig ───────────────────────────────────────────────────────────
SAFE_ADDRESS=0x0000000000000000000000000000000000000000

# ─── SIWE + JWT Authentication (Phase 19) ────────────────────────────────────
# Generate secret: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRY_MINUTES=1440
JWT_REFRESH_EXPIRY_DAYS=7

# ─── Gnosis Chain (Phase 19) ────────────────────────────────────────────────
# Set EVM_RPC_URL to Gnosis RPC for production. Keep as Anvil for local dev.
GNOSIS_RPC_FALLBACK=https://gnosis-pokt.nodies.app
GNOSISSCAN_API_KEY=

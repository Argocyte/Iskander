# Iskander Node — Frontend Environment Variables
# Copy to .env.local (never commit)

# Backend API URL (proxied via next.config.js rewrites in dev)
NEXT_PUBLIC_API_URL=http://localhost:8000

# WalletConnect Project ID (get one at https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Chain configuration
# 100 = Gnosis Chain (production), 31337 = Anvil (development)
NEXT_PUBLIC_CHAIN_ID=31337

# Contract addresses (from contracts/script/deployment.json after deploy)
NEXT_PUBLIC_COOP_IDENTITY_ADDRESS=
NEXT_PUBLIC_ISKANDER_ESCROW_ADDRESS=
NEXT_PUBLIC_ARBITRATION_REGISTRY_ADDRESS=
NEXT_PUBLIC_MACI_VOTING_ADDRESS=
NEXT_PUBLIC_INTERNAL_PAYROLL_ADDRESS=

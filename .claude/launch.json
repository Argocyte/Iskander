{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "FastAPI Backend",
      "runtimeExecutable": "py",
      "runtimeArgs": ["-3.10", "-m", "uvicorn", "backend.main:app", "--reload", "--host", "0.0.0.0", "--port", "8000", "--app-dir", "src/IskanderOS"],
      "port": 8000
    },
    {
      "name": "Next.js Frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "Streamlit Frontend",
      "runtimeExecutable": "py",
      "runtimeArgs": ["-3.10", "-m", "streamlit", "run", "frontend/app.py", "--server.port", "8501"],
      "port": 8501
    }
  ]
}
